//+------------------------------------------------------------------+
//|  SPX500 S/R + 100 EMA Strategy                                    |
//|  Version: 2.0 (Complete with Telegram Webhook)                    |
//|  Author: MiniMax Agent                                            |
//|                                                                  |
//|  STRATEGY RULES:                                                 |
//|  1. Price near Support/Resistance level                          |
//|  2. Price close to 100 EMA                                       |
//|  3. Reversal signal = Strong reversal expected                    |
//|  4. Breakout + Close = Strong direction                          |
//+------------------------------------------------------------------+

//@version=5
strategy("SPX500 S/R + 100 EMA Pro",
         overlay=true,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10,
         commission_type=strategy.commission.percent,
         commission_value=0.1)

// ============== INPUTS ==============

// Indicator Settings
emaLength     = input.int(100, "100 EMA Length", minval=1, group="Indicators")
atrLength     = input.int(14, "ATR Length", minval=1, group="Indicators")
emaProximity  = input.float(10.0, "EMA Proximity (points)", minval=1, group="Indicators")

// S/R Detection Settings
lookbackBars  = input.int(50, "Lookback for S/R", minval=10, group="Support & Resistance")
strengthThreshold = input.float(2.0, "Min Touches", minval=1, group="Support & Resistance")

// Breakout Settings
breakoutThreshold = input.float(5.0, "Breakout Confirmation (points)", minval=1, group="Breakout")

// Alert Settings
enableAlerts  = input.bool(true, "Enable Alerts", group="Alerts")
webhookURL     = input.string("", "Webhook URL", group="Alerts")

// Visual Settings
showEMALine   = input.bool(true, "Show 100 EMA", group="Visual")
showSRLines   = input.bool(true, "Show S/R Levels", group="Visual")
showLabels    = input.bool(true, "Show Labels", group="Visual")
showPanel     = input.bool(true, "Show Info Panel", group="Visual")

// ============== INDICATORS ==============

// 100 EMA
ema100 = ta.ema(close, emaLength)
plot(showEMALine ? ema100 : na, "100 EMA", color=color.new(color.orange, 0), linewidth=3)

// ATR
atr = ta.atr(atrLength)

// ============== SUPPORT & RESISTANCE ==============

// Pivot Highs/Lows
pivothigh = ta.pivothigh(high, lookbackBars, lookbackBars)
pivotlow = ta.pivotlow(low, lookbackBars, lookbackBars)

// Store S/R levels
var float[] resistanceLevels = array.new_float()
var float[] supportLevels = array.new_float()
var int[] resistanceTouches = array.new_int()
var int[] supportTouches = array.new_int()

// Add new resistance levels
if not na(pivothigh)
    array.push(resistanceLevels, pivothigh)
    array.push(resistanceTouches, 1)
    if array.size(resistanceLevels) > 5
        array.shift(resistanceLevels)
        array.shift(resistanceTouches)

// Add new support levels
if not na(pivotlow)
    array.push(supportLevels, pivotlow)
    array.push(supportTouches, 1)
    if array.size(supportLevels) > 5
        array.shift(supportLevels)
        array.shift(supportTouches)

// Find nearest levels
nearestResistance = 0.0
nearestSupport = 0.0
resistanceTouchesCount = 0
supportTouchesCount = 0

// Calculate nearest resistance
for i = 0 to array.size(resistanceLevels) - 1
    level = array.get(resistanceLevels, i)
    if level > close and (nearestResistance == 0 or level < nearestResistance)
        nearestResistance := level
        resistanceTouchesCount := array.get(resistanceTouches, i)

// Calculate nearest support
for i = 0 to array.size(supportLevels) - 1
    level = array.get(supportLevels, i)
    if level < close and (nearestSupport == 0 or level > nearestSupport)
        nearestSupport := level
        supportTouchesCount := array.get(supportTouches, i)

// EMA distance from levels
emaFromResistance = nearestResistance - ema100
emaFromSupport = ema100 - nearestSupport

// ============== PLOT S/R LEVELS ==============

// Resistance Line
var line resistLine = na
if showSRLines and nearestResistance > 0
    line.delete(resistLine)
    resistLine := line.new(x=bar_index - lookbackBars, y=nearestResistance, x2=bar_index, y2=nearestResistance, color=color.new(color.red, 30), width=2, style=line.style_dashed)
    if showLabels
        label.new(x=bar_index, y=nearestResistance, text="R: " + str.tostring(nearestResistance, format.mintick), color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)

// Support Line
var line supportLine = na
if showSRLines and nearestSupport > 0
    line.delete(supportLine)
    supportLine := line.new(x=bar_index - lookbackBars, y=nearestSupport, x2=bar_index, y2=nearestSupport, color=color.new(color.green, 30), width=2, style=line.style_dashed)
    if showLabels
        label.new(x=bar_index, y=nearestSupport, text="S: " + str.tostring(nearestSupport, format.mintick), color=color.green, textcolor=color.white, style=label.style_label_left, size=size.small)

// ============== SIGNAL DETECTION ==============

// Condition 1: Price near Resistance + close to EMA = Bearish Reversal
nearResistanceAndEMA = nearestResistance > 0 and
                       (close >= nearestResistance - emaProximity) and
                       (ema100 >= nearestResistance - emaProximity * 2)

// Condition 2: Price near Support + close to EMA = Bullish Reversal
nearSupportAndEMA = nearestSupport > 0 and
                    (close <= nearestSupport + emaProximity) and
                    (ema100 <= nearestSupport + emaProximity * 2)

// Condition 3: Breakout above resistance with close
resistanceBreakout = nearestResistance > 0 and
                     close > nearestResistance + breakoutThreshold and
                     close > open

// Condition 4: Breakout below support with close
supportBreakout = nearestSupport > 0 and
                  close < nearestSupport - breakoutThreshold and
                  close < open

// ============== PLOT SIGNALS ==============

// Reversal Signals
plotshape(showLabels and nearResistanceAndEMA and close < open, "Bearish Reversal", shape.circle, location.abovebar, color=color.new(color.red, 0), size=size.large, text="📍")
plotshape(showLabels and nearSupportAndEMA and close > open, "Bullish Reversal", shape.circle, location.belowbar, color=color.new(color.green, 0), size=size.large, text="📍")

// Breakout Signals
plotshape(showLabels and resistanceBreakout, "Bull Breakout", shape.arrowup, location.abovebar, color=color.new(color.blue, 0), size=size.large)
plotshape(showLabels and supportBreakout, "Bear Breakout", shape.arrowdown, location.belowbar, color=color.new(color.purple, 0), size=size.large)

// ============== ALERT MESSAGES ==============

// Bearish Reversal Alert
if enableAlerts and nearResistanceAndEMA and close < open
    alert_message = '{"signal_type": "REVERSAL_BEARISH", "price": ' + str.tostring(close, format.mintick) + ', "level": ' + str.tostring(nearestResistance, format.mintick) + ', "level_type": "RESISTANCE", "ema_distance": ' + str.tostring(emaFromResistance, format.mintick) + ', "strength": "STRONG", "time": "' + str.tostring(day(time)) + '-' + str.tostring(month(time)) + '-' + str.tostring(year(time)) + ' ' + str.tostring(hour(time)) + ':' + str.tostring(minute(time)) + '"}'
    alert(alert_message, alert.freq_once_per_bar_close)

// Bullish Reversal Alert
if enableAlerts and nearSupportAndEMA and close > open
    alert_message = '{"signal_type": "REVERSAL_BULLISH", "price": ' + str.tostring(close, format.mintick) + ', "level": ' + str.tostring(nearestSupport, format.mintick) + ', "level_type": "SUPPORT", "ema_distance": ' + str.tostring(emaFromSupport, format.mintick) + ', "strength": "STRONG", "time": "' + str.tostring(day(time)) + '-' + str.tostring(month(time)) + '-' + str.tostring(year(time)) + ' ' + str.tostring(hour(time)) + ':' + str.tostring(minute(time)) + '"}'
    alert(alert_message, alert.freq_once_per_bar_close)

// Bullish Breakout Alert
if enableAlerts and resistanceBreakout
    alert_message = '{"signal_type": "BREAKOUT_BULLISH", "price": ' + str.tostring(close, format.mintick) + ', "level": ' + str.tostring(nearestResistance, format.mintick) + ', "level_type": "RESISTANCE_BROKEN", "ema_distance": ' + str.tostring(emaFromResistance, format.mintick) + ', "strength": "VERY_STRONG", "time": "' + str.tostring(day(time)) + '-' + str.tostring(month(time)) + '-' + str.tostring(year(time)) + ' ' + str.tostring(hour(time)) + ':' + str.tostring(minute(time)) + '"}'
    alert(alert_message, alert.freq_once_per_bar_close)

// Bearish Breakout Alert
if enableAlerts and supportBreakout
    alert_message = '{"signal_type": "BREAKOUT_BEARISH", "price": ' + str.tostring(close, format.mintick) + ', "level": ' + str.tostring(nearestSupport, format.mintick) + ', "level_type": "SUPPORT_BROKEN", "ema_distance": ' + str.tostring(emaFromSupport, format.mintick) + ', "strength": "VERY_STRONG", "time": "' + str.tostring(day(time)) + '-' + str.tostring(month(time)) + '-' + str.tostring(year(time)) + ' ' + str.tostring(hour(time)) + ':' + str.tostring(minute(time)) + '"}'
    alert(alert_message, alert.freq_once_per_bar_close)

// ============== INFO TABLE ==============

if showPanel and barstate.islast
    var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

    // Title
    table.cell(infoTable, 0, 0, "📊 SPX500 Strategy", text_color=color.white, text_size=size.normal)
    table.merge_cells(infoTable, 0, 0, 1, 0)

    // EMA
    table.cell(infoTable, 0, 1, "100 EMA", text_color=color.orange)
    table.cell(infoTable, 1, 1, str.tostring(ema100, format.mintick), text_color=color.orange)

    // Resistance
    table.cell(infoTable, 0, 2, "Nearest R", text_color=color.red)
    table.cell(infoTable, 1, 2, nearestResistance > 0 ? str.tostring(nearestResistance, format.mintick) : "None", text_color=color.red)

    // Support
    table.cell(infoTable, 0, 3, "Nearest S", text_color=color.green)
    table.cell(infoTable, 1, 3, nearestSupport > 0 ? str.tostring(nearestSupport, format.mintick) : "None", text_color=color.green)

    // Signal
    table.cell(infoTable, 0, 4, "Signal", text_color=color.white)
    signalText = resistanceBreakout ? "⬆️ BULL BREAKOUT" :
                  supportBreakout ? "⬇️ BEAR BREAKOUT" :
                  nearResistanceAndEMA ? "📍 NEAR RESISTANCE" :
                  nearSupportAndEMA ? "📍 NEAR SUPPORT" : "➡️ NEUTRAL"
    signalColor = resistanceBreakout ? color.blue :
                  supportBreakout ? color.purple :
                  nearResistanceAndEMA ? color.red :
                  nearSupportAndEMA ? color.green : color.gray
    table.cell(infoTable, 1, 4, signalText, text_color=signalColor, text_size=size.small)

    // ATR
    table.cell(infoTable, 0, 5, "ATR (14)", text_color=color.yellow)
    table.cell(infoTable, 1, 5, str.tostring(atr, format.mintick), text_color=color.yellow)

// ============== NOTES ==============
// To use this script:
// 1. Copy this code to TradingView Pine Editor
// 2. Click "Add to Chart"
// 3. Create alerts with Webhook URL:
//    https://web-production-defc4.up.railway.app/webhook
// 4. Select the alert condition you want
// 5. Enable "Webhook URL" and paste the URL
// 6. Click "Create"
//+------------------------------------------------------------------+